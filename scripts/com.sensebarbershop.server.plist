<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sensebarbershop.server</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__SENSE_ROOT__/scripts/sense-server.sh</string>
        <string>start</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__SENSE_ROOT__</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__SENSE_ROOT__/backend/logs/launchd.log</string>
    <key>StandardErrorPath</key>
    <string>__SENSE_ROOT__/backend/logs/launchd-error.log</string>
</dict>
</plist>
