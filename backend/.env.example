# ===== CONFIGURAÇÃO DO SERVIDOR =====
PORT=3000
NODE_ENV=development

# ===== CONFIGURAÇÃO DE EMAIL =====
# Deixe vazio para desabilitar email temporariamente
# Para Gmail: https://myaccount.google.com/apppasswords
# Para Mailtrap: https://mailtrap.io

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=nao-responda@barbeariasense.pt

# ===== CONFIGURAÇÃO DO BANCO DE DADOS =====
DATABASE_PATH=./database/barbearia_sense.db

# ===== CONFIGURAÇÃO CORS =====
# Liste os domínios permitidos
CORS_ORIGIN=http://localhost:5500,http://localhost:3000,http://localhost:8000

# ===== AUTENTICAÇÃO =====
JWT_SECRET=altere-esta-chave-secreta-em-producao
FRONTEND_URL=http://localhost:3000

# Gmail (recomendado): EMAIL_HOST=smtp.gmail.com, EMAIL_USER=seu@gmail.com
# Crie uma palavra-passe de app em: https://myaccount.google.com/apppasswords

# ===== GOOGLE SIGN-IN =====
# Crie credenciais em: https://console.cloud.google.com/apis/credentials
# Tipo: "ID do cliente OAuth" → Aplicação Web
# Origens autorizadas: http://localhost:3000 e http://localhost:5500
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# Email(s) do administrador principal (separados por vírgula)
ADMIN_EMAILS=sensegeraldo2@gmail.com
