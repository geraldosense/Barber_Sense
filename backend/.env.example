# ===== CONFIGURAÇÃO DO SERVIDOR =====
PORT=3000
NODE_ENV=development

# ===== CONFIGURAÇÃO DE EMAIL =====
# Deixe vazio para desabilitar email temporariamente
# Para Gmail: https://myaccount.google.com/apppasswords
# Para Mailtrap: https://mailtrap.io

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=nao-responda@barbeariasense.pt

# ===== CONFIGURAÇÃO DO BANCO DE DADOS =====
DATABASE_PATH=./database/barbearia_sense.db

# ===== CONFIGURAÇÃO CORS =====
# Liste os domínios permitidos
CORS_ORIGIN=http://localhost:5500,http://localhost:3000,http://localhost:8000

# ===== AUTENTICAÇÃO =====
JWT_SECRET=altere-esta-chave-secreta-em-producao
FRONTEND_URL=http://localhost:5500
